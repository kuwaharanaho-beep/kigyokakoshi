  <script>
    // Lucideアイコンの初期化
    lucide.createIcons();

    // ローカルストレージに回答を一時保存
    function saveToLocal() {
      const data = {
        q1: document.getElementById('q1').value,
        q2: document.getElementById('q2').value,
        q3: document.getElementById('q3').value,
        studentId: document.getElementById('student-id').value,
        studentName: document.getElementById('student-name').value
      };
      
      localStorage.setItem('myfit_trass_prework', JSON.stringify(data));
      
      const statusMsg = document.getElementById('status-message');
      statusMsg.innerText = "ブラウザに回答を保存しました！当日まで消去されません。";
      statusMsg.className = "text-center text-xs font-semibold text-emerald-600 mt-2";
      
      setTimeout(() => {
        statusMsg.innerText = "";
      }, 4000);
    }

    // 保存データの自動読み込み
    window.addEventListener('load', () => {
      const savedData = localStorage.getItem('myfit_trass_prework');
      if (savedData) {
        const data = JSON.parse(savedData);
        document.getElementById('q1').value = data.q1 || '';
        document.getElementById('q2').value = data.q2 || '';
        document.getElementById('q3').value = data.q3 || '';
        document.getElementById('student-id').value = data.studentId || '';
        document.getElementById('student-name').value = data.studentName || '';
      }
    });

    // テキストファイルとして回答をダウンロード
    function downloadAnswers() {
      const q1 = document.getElementById('q1').value;
      const q2 = document.getElementById('q2').value;
      const q3 = document.getElementById('q3').value;
      const studentId = document.getElementById('student-id').value || "未入力";
      const studentName = document.getElementById('student-name').value || "未入力";

      const text = `【事前学習ワークシート】起業家講師 Night：山田真愛 氏 ＆ 越智健心 氏
--------------------------------------------------
■ 学籍番号 : ${studentId}
■ お名前   : ${studentName}
--------------------------------------------------

Q1. 【パーソナライズとヘルスケア】あなたは普段、生活習慣や健康について「もっと自分に最適化されたケアが欲しい」と感じることはありますか？また、パーソナライズされたサービスにどんな期待をしますか？
[回答]:
${q1}

--------------------------------------------------

Q2. 【テクノロジーによる産業変革】不動産や教育など「歴史が長くて少し古そう（アナログ）」に感じる業界で、テクノロジーを使ってもっと効率よく、働きやすくできると思うアイデアは何かありますか？
[回答]:
${q2}

--------------------------------------------------

Q3. 当日のお二人とのセッションに向けて、聞いてみたい質問
[回答]:
${q3}

--------------------------------------------------
振り返り・学習用。お疲れ様でした！講義当日をお楽しみに！`;

      const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = `事前学習ワーク_${studentName}.txt`;
      link.click();
      URL.revokeObjectURL(link.href);
    }
